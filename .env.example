# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-login

# Optional — filter to a specific repo (org/repo). Leave blank for all repos.
GITHUB_REPO=mobly-app/monorepo

# Optional (defaults shown)
POLL_INTERVAL_MS=60000
PORT=3000

# Claude PR review
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# SMTP (for emailing reviews) — Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=your-app-password   # https://myaccount.google.com/apppasswords
#   SMTP_FROM=PR Dashboard <you@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Where to send reviews (defaults to cameron@getmobly.com)
REVIEW_TO_EMAIL=cameron@getmobly.com
