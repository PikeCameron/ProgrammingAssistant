# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-login

# Optional — filter to a specific repo (org/repo). Leave blank for all repos.
GITHUB_REPO=mobly-app/monorepo

# Optional (defaults shown)
POLL_INTERVAL_MS=60000
PORT=3000

# Mac review server URL (run ~/review-server.js on your Mac first).
# This is the default; it can be overridden per-device from the app's
# Settings panel (gear icon in the footer) without editing .env or
# restarting the service — useful when the Mac's IP changes on a
# network where the .local mDNS hostname doesn't resolve.
MAC_REVIEW_URL=http://camerons-macbook-pro.local:3002/review
