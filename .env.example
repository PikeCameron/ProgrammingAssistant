# Required
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_USERNAME=your-github-login

# Optional — filter to a specific repo (org/repo). Leave blank for all repos.
GITHUB_REPO=mobly-app/monorepo

# Optional (defaults shown)
POLL_INTERVAL_MS=60000
PORT=3000

# SMTP (for emailing reviews) — Gmail example:
#   Generate an app password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=PR Dashboard <you@gmail.com>

# Where to send reviews (defaults to cameron@getmobly.com)
REVIEW_TO_EMAIL=cameron@getmobly.com
